# FastAPI Environment
DEBUG=true
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentos
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-this-in-production
AGENTOS_INTERNAL_API_KEY=change-this-in-production
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM Provider API Keys (BYOD)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=

# Integrations
OPENCLAUDE_GRPC_HOST=localhost
OPENCLAUDE_GRPC_PORT=50051
HERMES_CONFIG_PATH=~/.hermes
OPEN_DESIGN_API_KEY=
OPEN_DESIGN_ENDPOINT=https://api.open-design.io

# Vector DB
