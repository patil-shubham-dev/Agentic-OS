{
  "name": "@agentos/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AgentOS Studio — Native Desktop Application",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win",
    "build:mac": "tsc && electron-builder --mac",
    "build:linux": "tsc && electron-builder --linux",
    "package": "tsc && electron-builder --publish=never",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist out",
    "postinstall": "echo skipping rebuild"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "keytar": "^7.9.0",
    "next": "^15.0.0",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "electron": "^33.1.0",
    "electron-builder": "^25.1.0",
    "@electron/rebuild": "^3.6.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
