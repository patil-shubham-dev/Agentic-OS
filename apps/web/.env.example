# ──────────────────────────────────────────────
# AgentOS Studio — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
#
#   cp apps/web/.env.example apps/web/.env.local
#
# Then edit apps/web/.env.local with your credentials.
# ──────────────────────────────────────────────

# === Required — Supabase (Backend Database) ===
# Create a free project at https://supabase.com
# Then get your credentials from Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Required — Encryption Key ===
# Used to encrypt provider API keys at rest (AES-256-GCM).
# Generate a 32-byte (64 hex chars) key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENTOS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# === Public (Client-side) Supabase Keys ===
# These are safe to expose to the browser.
# From the same Supabase project settings page.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Optional — Desktop App ===
# AGENTOS_WEB_URL=http://localhost:3000
# AGENTOS_WEB_PORT=3000

# === Optional — Overrides ===
# AGENTOS_DEFAULT_PROJECT_ID=my-project
# AGENTOS_TELEMETRY_DISABLED=1
# NEXT_PUBLIC_APP_VERSION=0.1.0
