#!/usr/bin/env bash
# AgenticOS — Linux Desktop Entry
[Desktop Entry]
Type=Application
Name=AgenticOS
Comment=Your AI operating system for development
Exec=/opt/AgenticOS/AgenticOS
Icon=agenticos
Terminal=false
Categories=Development;Utility;
StartupNotify=true
StartupWMClass=AgenticOS
MimeType=x-scheme-handler/agenticos;
