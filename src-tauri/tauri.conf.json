{
  "productName": "AgenticOS",
  "version": "2.1.0",
  "identifier": "com.agenticos.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {}
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowPosition": { "x": 400, "y": 200 },
        "windowSize": { "width": 660, "height": 440 },
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 }
      }
    },
    "linux": {
      "deb": {
        "depends": [],
        "desktopTemplate": "../linux/agenticos.desktop"
      },
      "rpm": {
        "depends": []
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "AgenticOS",
        "label": "main",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "maximized": false,
        "decorations": true,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "url": "/"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; connect-src 'self' ws: wss: https:; font-src 'self' data:; media-src 'self' asset: blob:"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "AgenticOS"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": ["https://releases.agenticos.ai/update/{{target}}/{{current_version}}"],
      "pubkey": "YOUR_UPDATER_SIGNING_PUBLIC_KEY_HERE"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["agenticos"]
      }
    },
    "shell": {
      "open": true
    },
    "notification": null
  }
}
