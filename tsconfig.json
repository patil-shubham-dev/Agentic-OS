{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@agentic-os/shared": ["./packages/shared/src"],
      "@agentic-os/shared/*": ["./packages/shared/src/*"],
      "@agentic-os/ui": ["./packages/ui/src"],
      "@agentic-os/ui/*": ["./packages/ui/src/*"],
      "@agentic-os/providers": ["./packages/providers/src"],
      "@agentic-os/providers/*": ["./packages/providers/src/*"]
    }
  },
  "include": ["src", "packages/shared/src", "packages/ui/src", "packages/providers/src"]
}
